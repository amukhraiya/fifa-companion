{
  "name": "@fifa/ai",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@fifa/config": "workspace:*",
    "@fifa/shared-types": "workspace:*",
    "@google/genai": "^2.12.0",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
