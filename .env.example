# Database Configuration (PostgreSQL with pgvector or standard schema)
DATABASE_URL="postgresql://user:password@localhost:5432/fifa_companion?schema=public"

# Backend API Service Configuration
PORT=3001
NODE_ENV="production"
JWT_SECRET="replace_with_a_secure_jwt_secret_in_production"

# Authentication Provider ("mock" for sandbox/demo, "firebase" for production)
AUTH_PROVIDER="mock"
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_API_KEY="your-firebase-web-api-key"

# Frontend Configuration
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Gemini AI API Key
GEMINI_API_KEY="your-google-gemini-api-key"
GEMINI_MODEL="gemini-1.5-flash"
